---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A fast Astro blog on Cloudflare Workers." } = Astro.props;
const pageTitle = title === "Home" ? "Edge Notes" : `${title} | Edge Notes`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Edge Notes home">Edge Notes</a>
      <nav aria-label="Primary navigation">
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>Built with Astro and Cloudflare Workers Static Assets.</p>
    </footer>
  </body>
</html>
